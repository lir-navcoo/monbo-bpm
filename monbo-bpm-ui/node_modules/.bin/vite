#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/lirui/.pnpm-store/virtual/vite@8.0.9_@types+node@24.12.2_jiti@2.6.1/node_modules/vite/node_modules:/Users/lirui/.pnpm-store/virtual/vite@8.0.9_@types+node@24.12.2_jiti@2.6.1/node_modules:/Users/lirui/.pnpm-store/virtual/node_modules"
else
  export NODE_PATH="/Users/lirui/.pnpm-store/virtual/vite@8.0.9_@types+node@24.12.2_jiti@2.6.1/node_modules/vite/node_modules:/Users/lirui/.pnpm-store/virtual/vite@8.0.9_@types+node@24.12.2_jiti@2.6.1/node_modules:/Users/lirui/.pnpm-store/virtual/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../vite/bin/vite.js" "$@"
else
  exec node  "$basedir/../vite/bin/vite.js" "$@"
fi
